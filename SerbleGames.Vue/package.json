{
  "name": "serble-games",
  "description": "Launcher for the Serble game distribution platform.",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "homepage": "https://games.serble.net",
  "bugs": {
    "url": "https://github.com/Serble/SerbleGames/issues",
    "email": "support@serble.net"
  },
  "author": {
    "name": "CoPokBl",
    "email": "copokbl@serble.net",
    "url": "copokbl.net"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:renderer": "vite --mode electron",
    "electron:start": "electron .",
    "electron:dev": "concurrently \"npm run electron:renderer\" \"wait-on http://localhost:3000 && npm run electron:start\"",
    "electron:build": "vite build --mode electron && electron-builder",
    "electron:build:linux": "vite build --mode electron && electron-builder --linux",
    "electron:build:win": "vite build --mode electron && electron-builder --win",
    "electron:build:mac": "vite build --mode electron && electron-builder --mac"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.7.9",
    "lucide-vue-next": "^0.475.0",
    "marked": "^14.1.3",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "net.serble.games",
    "productName": "Serble Games",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Game"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
